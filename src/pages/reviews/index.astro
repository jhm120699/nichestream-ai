---
import Layout from '../../layouts/Layout.astro';
const reviews = Object.values(import.meta.glob('./*.md', { eager: true }));

// Sort reviews by rating (highest first)
const sortedReviews = reviews.sort((a: any, b: any) => b.frontmatter.rating - a.frontmatter.rating);
---

<Layout title="Product Intelligence Reports">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 relative">
        <div class="absolute top-0 right-0 -z-10 w-64 h-64 bg-blue-100/30 rounded-full blur-3xl opacity-50"></div>
        
        <header class="mb-16">
            <h1 class="text-4xl md:text-5xl font-black text-slate-950 mb-4 tracking-tight">Intelligence Reports</h1>
            <p class="text-lg text-slate-600 max-w-2xl leading-relaxed">
                Objective, AI-driven analysis of the market's most trending software and digital assets.
            </p>
        </header>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
			{sortedReviews.map((review: any) => (
				<a href={review.url} class="group relative block rounded-3xl transition-all duration-500 hover:-translate-y-2">
                    <!-- Card Background and Glow -->
                    <div class="absolute -inset-0.5 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-3xl opacity-0 group-hover:opacity-10 blur transition duration-500"></div>
                    
                    <div class="relative h-full flex flex-col p-8 rounded-3xl bg-white/70 backdrop-blur-sm border border-slate-200/60 shadow-sm shadow-slate-200/50 group-hover:border-blue-200 group-hover:shadow-xl transition-all duration-500 overflow-hidden">
                        <!-- Decorative background light -->
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-50/50 rounded-full blur-2xl transition-transform group-hover:scale-150 duration-700"></div>

                        <div class="relative z-10 flex justify-between items-center mb-6">
                            <span class="px-3 py-1 rounded-full bg-slate-900 text-[10px] font-black text-white uppercase tracking-widest shadow-sm">Report</span>
                            <div class="flex items-center space-x-1">
                                <span class="text-sm font-bold text-slate-950">{review.frontmatter.rating}</span>
                                <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20">
                                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                </svg>
                            </div>
                        </div>

                        <div class="relative z-10 flex-grow">
                            <h2 class="text-2xl font-extrabold text-slate-950 mb-4 tracking-tight leading-tight group-hover:text-blue-600 transition-colors">
                                {review.frontmatter.title.replace('Unlock Your Workflow Potential: Review of ', '').replace('Review of ', '')}
                            </h2>
                            <p class="text-slate-600 text-sm leading-relaxed line-clamp-4">
                                {review.frontmatter.description}
                            </p>
                        </div>

                        <div class="relative z-10 mt-8 pt-6 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-blue-600 font-bold text-xs uppercase tracking-widest transition-transform group-hover:translate-x-1">Access Analysis</span>
                            <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center group-hover:bg-blue-600 group-hover:text-white transition-all">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
				</a>
			))}
		</div>
	</section>
</Layout>
