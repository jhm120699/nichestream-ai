---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI Comparative Intelligence">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center relative">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-indigo-100 rounded-full blur-3xl opacity-20 -z-10"></div>
        
		<div class="w-24 h-24 bg-gradient-to-br from-blue-600 to-indigo-600 text-white rounded-3xl flex items-center justify-center mx-auto mb-10 shadow-lg shadow-blue-200 rotate-3 transition-transform hover:rotate-0 duration-500">
			<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 000-4zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
			</svg>
		</div>
        
		<h1 class="text-4xl md:text-5xl font-black text-slate-950 tracking-tight mb-8">
			Side-by-Side Intelligence
		</h1>
		<p class="text-xl text-slate-600 max-w-2xl mx-auto mb-12 leading-relaxed">
			Our AI engine is currently processing millions of feature vectors to generate deep-dive, head-to-head comparisons. Check back shortly for automated, data-driven "Vs" reports.
		</p>
        
		<div class="flex justify-center">
			<a href="/reviews" class="group relative px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(30,41,59,0.3)] overflow-hidden">
                <span class="relative z-10">Explore In-Depth Reviews</span>
                <div class="absolute inset-0 bg-gradient-to-r from-blue-600 to-indigo-600 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </a>
		</div>

        <!-- Placeholder visual -->
        <div class="mt-20 max-w-4xl mx-auto grid grid-cols-2 gap-4 opacity-20 pointer-events-none">
            <div class="h-40 rounded-3xl border-2 border-dashed border-slate-300"></div>
            <div class="h-40 rounded-3xl border-2 border-dashed border-slate-300"></div>
        </div>
	</section>
</Layout>
