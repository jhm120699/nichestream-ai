---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AI Comparative Intelligence">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center relative">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-emerald-500/5 rounded-full blur-[120px] -z-10"></div>
        
		<div class="w-24 h-24 bg-gradient-to-br from-emerald-500 to-teal-500 text-slate-950 rounded-3xl flex items-center justify-center mx-auto mb-10 shadow-lg shadow-emerald-500/10 rotate-3 transition-transform hover:rotate-0 duration-500">
			<!-- Clean math/comparison visual using standard shapes, NO arrows or stars -->
            <span class="text-3xl font-black">VS</span>
		</div>
        
		<h1 class="text-4xl md:text-5xl font-black text-slate-100 tracking-tight mb-8">
			Side-by-Side Intelligence
		</h1>
		<p class="text-xl text-slate-400 max-w-2xl mx-auto mb-12 leading-relaxed">
			Our AI engine is currently processing millions of feature vectors to generate deep-dive, head-to-head comparisons. Check back shortly for automated, data-driven reports.
		</p>
        
		<div class="flex justify-center">
			<a href="/reviews" class="group relative px-8 py-4 bg-gradient-to-r from-emerald-500 to-teal-500 text-slate-950 rounded-2xl font-bold transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(16,185,129,0.2)] overflow-hidden">
                <span class="relative z-10">Explore In-Depth Reviews</span>
            </a>
		</div>

        <!-- Placeholder visual -->
        <div class="mt-20 max-w-4xl mx-auto grid grid-cols-2 gap-6 opacity-30 pointer-events-none">
            <div class="h-40 rounded-3xl border border-slate-800 bg-[#0d1527]/20 backdrop-blur-sm"></div>
            <div class="h-40 rounded-3xl border border-slate-800 bg-[#0d1527]/20 backdrop-blur-sm"></div>
        </div>
	</section>
</Layout>
