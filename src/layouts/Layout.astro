---
import '../styles/global.css';
import FiverrCTA from '../components/FiverrCTA.astro';

interface Props {
    title: string;
    description?: string;
    productName?: string;
}

const { title, description = "AI-powered product reviews and comparisons", productName: passedProductName } = Astro.props;

// Detect if we are on a review page to show the CTA
const isReviewPage = Astro.url.pathname.startsWith('/reviews/');

// Dynamic product name extraction for the review page Fiverr CTA
let productName = passedProductName;
if (!productName && isReviewPage) {
    const frontmatter = Astro.props.frontmatter;
    if (frontmatter) {
        if (frontmatter.json_ld) {
            try {
                const parsed = JSON.parse(frontmatter.json_ld);
                if (parsed.brand) {
                    productName = typeof parsed.brand === 'object' ? parsed.brand.name : parsed.brand;
                } else if (parsed.name) {
                    productName = parsed.name;
                }
            } catch (e) {
                // Regex fallback for JSON-LD parsing errors
                const brandMatch = frontmatter.json_ld.match(/"brand"\s*:\s*"([^"]+)"/);
                const nameMatch = frontmatter.json_ld.match(/"name"\s*:\s*"([^"]+)"/);
                if (brandMatch && brandMatch[1]) {
                    productName = brandMatch[1];
                } else if (nameMatch && nameMatch[1]) {
                    productName = nameMatch[1];
                }
            }
        }
    }
    
    // Fallback: extract and format from slug if still default or too generic
    if (!productName || productName === "this product") {
        const pathParts = Astro.url.pathname.split('/').filter(Boolean);
        const slug = pathParts[pathParts.length - 1];
        if (slug) {
            productName = slug
                .split('-')
                .map(word => {
                    const lower = word.toLowerCase();
                    if (lower === 'ai') return 'AI';
                    if (lower === 'pdf') return 'PDF';
                    return word.charAt(0).toUpperCase() + word.slice(1);
                })
                .join(' ');
        }
    }
}
if (!productName) {
    productName = "this product";
}
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="generator" content={Astro.generator} />
        <title>{title} | NicheStream AI</title>
    </head>
    <body class="bg-[#070a13] text-slate-100 font-sans selection:bg-emerald-500/20 selection:text-emerald-300 min-h-screen flex flex-col relative overflow-x-hidden">
        <!-- Background decorative elements -->
        <div class="fixed inset-0 -z-10 h-full w-full bg-[radial-gradient(rgba(59,130,246,0.08)_1px,transparent_1px)] [background-size:20px_20px] opacity-70"></div>
        <div class="fixed top-0 left-1/4 -z-10 h-[600px] w-[600px] bg-[radial-gradient(circle_at_center,rgba(59,130,246,0.07),transparent_70%)] blur-2xl"></div>
        <div class="fixed bottom-0 right-1/4 -z-10 h-[600px] w-[600px] bg-[radial-gradient(circle_at_center,rgba(16,185,129,0.04),transparent_70%)] blur-2xl"></div>

        <nav class="sticky top-0 z-50 bg-[#070a13]/80 backdrop-blur-md border-b border-slate-800/60">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex justify-between h-20">
                    <div class="flex">
                        <a href="/" class="flex-shrink-0 flex items-center group">
                            <span class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-emerald-400 via-teal-300 to-blue-500 transition-all group-hover:opacity-80">
                                NicheStream AI
                            </span>
                        </a>
                    </div>
                    <div class="hidden sm:flex sm:items-center sm:space-x-8">
                        <a href="/reviews" class="text-slate-300 hover:text-emerald-400 font-medium transition-colors">Reviews</a>
                        <a href="/comparisons" class="text-slate-300 hover:text-emerald-400 font-medium transition-colors">Comparisons</a>
                    </div>
                </div>
            </div>
        </nav>

        <main class="flex-grow">
            {isReviewPage ? (
                <div class="max-w-4xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
                    <article class="bg-[#0d1527]/60 backdrop-blur-md shadow-2xl shadow-slate-950/40 my-8 rounded-3xl border border-slate-800/80 p-8 md:p-12 relative overflow-hidden group">
                        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent pointer-events-none"></div>
                        <div class="prose prose-invert prose-slate max-w-none prose-headings:font-bold prose-headings:text-slate-100 prose-a:text-emerald-400 hover:prose-a:text-emerald-300 relative z-10">
                            <slot />
                        </div>
                        
                        <!-- Fiverr CTA Section -->
                        <div class="mt-20 border-t border-slate-800/80 pt-12 relative z-10">
                            <FiverrCTA productName={productName} />
                        </div>
                    </article>
                </div>
            ) : (
                <slot />
            )}
        </main>

        <footer class="bg-[#030712] text-slate-400 py-16 mt-20 relative overflow-hidden border-t border-slate-900">
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-slate-800 to-transparent"></div>
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                    <div>
                        <span class="text-2xl font-bold text-white mb-6 block">NicheStream AI</span>
                        <p class="max-w-md text-slate-400 leading-relaxed">
                            Premium programmatic AI reviews for the modern niche investigator. Helping you discover high-value opportunities with data-driven clarity.
                        </p>
                    </div>
                    <div class="md:text-right flex flex-col justify-end">
                        <div class="flex md:justify-end space-x-6 mb-8 text-sm font-medium">
                            <a href="/reviews" class="hover:text-white transition-colors">Latest Reviews</a>
                            <a href="/comparisons" class="hover:text-white transition-colors">Comparisons</a>
                        </div>
                        <p class="text-sm">&copy; {new Date().getFullYear()} NicheStream AI. Crafted with precision for 100% passive growth.</p>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');
    
    :root {
        --font-sans: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif;
    }

    html {
        font-family: var(--font-sans);
        scroll-behavior: smooth;
    }

    /* Simple custom scrollbar */
    ::-webkit-scrollbar {
        width: 10px;
    }
    ::-webkit-scrollbar-track {
        background-color: #070a13;
    }
    ::-webkit-scrollbar-thumb {
        background-color: #1e293b;
        border-radius: 9999px;
    }
</style>
