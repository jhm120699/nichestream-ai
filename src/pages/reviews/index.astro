---
import Layout from '../../layouts/Layout.astro';
const reviews = Object.values(import.meta.glob('./*.md', { eager: true }));

// Sort reviews by rating (highest first)
const sortedReviews = reviews.sort((a: any, b: any) => b.frontmatter.rating - a.frontmatter.rating);
---

<Layout title="Product Intelligence Reports">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 relative">
        <!-- Background decorative glows -->
        <div class="absolute top-0 right-0 -z-10 w-80 h-80 bg-blue-500/5 rounded-full blur-[100px] opacity-70"></div>
        <div class="absolute bottom-0 left-0 -z-10 w-80 h-80 bg-emerald-500/5 rounded-full blur-[100px] opacity-70"></div>
        
        <header class="mb-20">
            <h1 class="text-4xl md:text-5xl font-black text-slate-100 mb-6 tracking-tight">Intelligence Reports</h1>
            <p class="text-lg text-slate-400 max-w-2xl leading-relaxed">
                Objective, AI-driven analysis of the market's most trending software and digital assets.
            </p>
        </header>

		<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
			{sortedReviews.map((review: any) => (
				<a href={review.url} class="group relative block rounded-3xl transition-all duration-500 hover:-translate-y-2">
                    <!-- Subtle Card Glow -->
                    <div class="absolute -inset-px bg-gradient-to-br from-emerald-500/20 to-blue-500/20 rounded-3xl opacity-0 group-hover:opacity-100 blur-sm transition-all duration-500"></div>
                    
                    <div class="relative h-full flex flex-col p-8 rounded-3xl bg-[#0d1527]/50 backdrop-blur-md border border-slate-800/80 shadow-2xl shadow-slate-950/40 group-hover:border-emerald-500/30 transition-all duration-500 overflow-hidden">
                        <!-- Decorative glow dot -->
                        <div class="absolute -top-10 -right-10 w-32 h-32 bg-emerald-500/5 rounded-full blur-2xl transition-transform group-hover:scale-150 duration-700"></div>

                        <div class="relative z-10 flex justify-between items-center mb-6">
                            <span class="px-2.5 py-1 rounded-full bg-blue-500/10 border border-blue-500/20 text-[10px] font-black text-blue-400 uppercase tracking-widest">Report</span>
                            <span class="px-2.5 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20 text-xs font-bold text-emerald-400">Score: {review.frontmatter.rating} / 10</span>
                        </div>

                        <div class="relative z-10 flex-grow">
                            <h2 class="text-2xl font-extrabold text-slate-100 mb-4 tracking-tight leading-tight group-hover:text-emerald-400 transition-colors">
                                {review.frontmatter.title.replace('Unlock Your Workflow Potential: Review of ', '').replace('Review of ', '')}
                            </h2>
                            <p class="text-slate-400 text-sm leading-relaxed line-clamp-4">
                                {review.frontmatter.description}
                            </p>
                        </div>

                        <div class="relative z-10 mt-8 pt-6 border-t border-slate-800/60 flex items-center justify-between">
                            <span class="text-emerald-400 font-bold text-xs uppercase tracking-widest group-hover:text-emerald-300 transition-colors">Access Analysis</span>
                            <span class="text-slate-500 text-xs font-semibold group-hover:text-slate-300 transition-colors">Read Report</span>
                        </div>
                    </div>
				</a>
			))}
		</div>
	</section>
</Layout>
