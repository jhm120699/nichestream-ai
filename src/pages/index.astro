---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 text-center">
		<h1 class="text-5xl font-extrabold text-slate-900 tracking-tight mb-8">
			Programmatic AI Reviews for <span class="text-blue-600">Passive Income</span>
		</h1>
		<p class="text-xl text-slate-600 max-w-3xl mx-auto mb-12">
			Discover the best software and products, analyzed by AI to help you make informed decisions instantly.
		</p>
		<div class="flex justify-center gap-4">
			<a href="/reviews" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition-colors">
				Browse Reviews
			</a>
			<a href="/comparisons" class="bg-white text-slate-900 border border-slate-200 px-8 py-3 rounded-lg font-semibold hover:bg-slate-50 transition-colors">
				View Comparisons
			</a>
		</div>
	</section>

	<section class="bg-white py-24">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<h2 class="text-3xl font-bold text-slate-900 mb-12 text-center">How It Works</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-12">
				<div class="p-8 rounded-2xl bg-slate-50 border border-slate-100">
					<div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center font-bold text-xl mb-6">1</div>
					<h3 class="text-xl font-bold mb-4">Smart Scraping</h3>
					<p class="text-slate-600">We automatically track trending products and software across multiple niche categories.</p>
				</div>
				<div class="p-8 rounded-2xl bg-slate-50 border border-slate-100">
					<div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center font-bold text-xl mb-6">2</div>
					<h3 class="text-xl font-bold mb-4">AI Analysis</h3>
					<p class="text-slate-600">Our AI analyzes features, pros, and cons to generate highly detailed and honest reviews.</p>
				</div>
				<div class="p-8 rounded-2xl bg-slate-50 border border-slate-100">
					<div class="w-12 h-12 bg-blue-100 text-blue-600 rounded-lg flex items-center justify-center font-bold text-xl mb-6">3</div>
					<h3 class="text-xl font-bold mb-4">SEO Optimized</h3>
					<p class="text-slate-600">Every page is built for speed and search engines, ensuring maximum visibility and passive income.</p>
				</div>
			</div>
		</div>
	</section>
</Layout>
