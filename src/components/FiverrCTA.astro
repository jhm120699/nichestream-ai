---
interface Props {
    productName?: string;
}

const { productName = "this product" } = Astro.props;

// Use the env var requested by the lead
const fiverrLink = import.meta.env.FIVERR_AFFILIATE_URL || "https://go.fiverr.com/visit/?bta=618c1ae9&brand=fiverrcpa";
---

<div class="my-12 p-8 bg-gradient-to-br from-emerald-950/30 via-[#0d1527]/50 to-[#030712]/50 border border-emerald-500/15 rounded-3xl shadow-xl overflow-hidden relative group">
    <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
    <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
        <div class="flex-1">
            <h3 class="text-xl font-bold text-emerald-400 mb-2">Need professional help?</h3>
            <p class="text-slate-300 text-base leading-relaxed">
                Need help setting up <strong>{productName}</strong>, designing custom assets, or writing professional copy? 
                Hire a top-rated freelance expert on Fiverr to get it done right!
            </p>
        </div>
        <div class="flex-shrink-0">
            <a 
                href={fiverrLink}
                target="_blank"
                rel="nofollow noopener noreferrer"
                class="inline-flex items-center px-6 py-3.5 bg-emerald-500 hover:bg-emerald-400 text-slate-950 font-black rounded-xl transition-all transform hover:scale-105 shadow-md shadow-emerald-500/10 hover:shadow-emerald-500/20 text-sm tracking-wider uppercase"
            >
                Hire an Expert
            </a>
        </div>
    </div>
    <!-- Subtle glow dot in background -->
    <div class="absolute -right-10 -bottom-10 w-40 h-40 bg-emerald-500/5 rounded-full blur-3xl opacity-50 pointer-events-none"></div>
</div>
